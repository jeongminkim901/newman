<h1>Run <%= @run.id %></h1>

<div class="run-meta">
  <div class="card">
    <div class="meta-grid">
      <div>
        <div class="meta-label">Name</div>
        <div class="meta-value"><%= @run.name.presence || "-" %></div>
      </div>
      <div>
        <div class="meta-label">Mode</div>
        <div class="meta-value"><%= @run.run_mode %></div>
      </div>
      <div>
        <div class="meta-label">Status</div>
        <div class="meta-value"><span class="badge badge-<%= @run.status %>"><%= @run.status %></span></div>
      </div>
      <div>
        <div class="meta-label">Queued</div>
        <div class="meta-value"><%= @run.queued_at || "-" %></div>
      </div>
      <div>
        <div class="meta-label">Started</div>
        <div class="meta-value"><%= @run.started_at || "-" %></div>
      </div>
      <div>
        <div class="meta-label">Finished</div>
        <div class="meta-value"><%= @run.finished_at || "-" %></div>
      </div>
      <div>
        <div class="meta-label">Duration</div>
        <div class="meta-value"><%= @run.duration_ms ? "#{@run.duration_ms} ms" : "-" %></div>
      </div>
      <div>
        <div class="meta-label">Exit Code</div>
        <div class="meta-value"><%= @run.exit_code.nil? ? "-" : @run.exit_code %></div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="meta-grid">
    <div>
      <div class="meta-label">Collection</div>
      <div class="meta-value"><%= @run.collection_path %></div>
    </div>
    <div>
      <div class="meta-label">Environment</div>
      <div class="meta-value"><%= @run.environment_path || "-" %></div>
    </div>
  </div>

  <div class="report-links">
    <% if @run.report_html_path.present? %>
      <a class="btn" href="<%= report_run_path(@run, kind: 'html') %>">View HTML Report</a>
    <% end %>
    <% if @run.report_json_path.present? %>
      <a class="btn ghost" href="<%= report_run_path(@run, kind: 'json') %>">View JSON Report</a>
    <% end %>
  </div>
</div>

<% if @stats[:total] > 0 %>
  <div class="summary-grid">
    <div class="card stat">
      <div class="stat-label">Total</div>
      <div class="stat-value"><%= @stats[:total] %></div>
    </div>
    <div class="card stat">
      <div class="stat-label">Failed</div>
      <div class="stat-value"><%= @stats[:failed] %></div>
    </div>
    <div class="card stat">
      <div class="stat-label">2xx</div>
      <div class="stat-value"><%= @stats[:ok] %></div>
    </div>
    <div class="card stat">
      <div class="stat-label">3xx</div>
      <div class="stat-value"><%= @stats[:redirect] %></div>
    </div>
    <div class="card stat">
      <div class="stat-label">4xx</div>
      <div class="stat-value"><%= @stats[:client_error] %></div>
    </div>
    <div class="card stat">
      <div class="stat-label">5xx</div>
      <div class="stat-value"><%= @stats[:server_error] %></div>
    </div>
  </div>

  <% if @failed_executions.any? %>
    <div class="card">
      <h2>Failures</h2>
      <ul class="failure-list">
        <% @failed_executions.first(10).each do |ex| %>
          <li>
            <strong><%= ex[:method] %> <%= ex[:status] || "-" %></strong>
            <span><%= ex[:name] %></span>
            <% if ex[:error].present? %>
              <div class="failure-detail"><%= ex[:error] %></div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card">
    <div class="table-toolbar">
      <div class="filter-bar">
        <button class="chip active" data-filter="all">All</button>
        <button class="chip" data-filter="2">2xx</button>
        <button class="chip" data-filter="3">3xx</button>
        <button class="chip" data-filter="4">4xx</button>
        <button class="chip" data-filter="5">5xx</button>
        <button class="chip" data-filter="error">Errors</button>
      </div>
      <input class="table-search" type="text" placeholder="Search method, name, url..." />
    </div>

    <div class="table-wrap">
      <table class="runs-table" id="exec-table">
        <thead>
          <tr>
            <th data-sort="method">Method</th>
            <th data-sort="status">Status</th>
            <th data-sort="time">Time</th>
            <th data-sort="name">Name</th>
            <th data-sort="url">URL</th>
          </tr>
        </thead>
        <tbody>
          <% @executions.each do |ex| %>
            <tr data-status-group="<%= ex[:status_group] %>"
                data-failed="<%= ex[:failed] || ex[:error].present? %>"
                data-method="<%= ex[:method].to_s %>"
                data-status="<%= ex[:status].to_i %>"
                data-time="<%= ex[:time_ms].to_i %>"
                data-name="<%= ex[:name].to_s %>"
                data-url="<%= ex[:url].to_s %>">
              <td class="mono"><%= ex[:method] %></td>
              <td><%= ex[:status] || "-" %></td>
              <td><%= ex[:time_ms] ? "#{ex[:time_ms]} ms" : "-" %></td>
              <td><%= ex[:name] %></td>
              <td class="muted"><%= ex[:url] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<div class="card">
  <div class="log-header">
    <h2>Live Logs</h2>
    <div class="log-actions">
      <button class="btn ghost" id="log-toggle">Auto-scroll: on</button>
      <button class="btn ghost" id="log-copy">Copy</button>
    </div>
  </div>
  <pre class="log" id="log-stream" data-run-id="<%= @run.id %>" data-status="<%= @run.status %>"><%= @run.log_text.to_s %></pre>
</div>

<div class="card">
  <h2>Stderr</h2>
  <pre class="log error"><%= @run.stderr.to_s %></pre>
</div>

<div class="page-actions">
  <a class="btn ghost" href="<%= runs_path %>">Back to runs</a>
</div>

<script>
  (function() {
    var logEl = document.getElementById("log-stream");
    if (!logEl) return;

    var status = logEl.dataset.status;
    var autoScroll = true;
    var toggleBtn = document.getElementById("log-toggle");
    var copyBtn = document.getElementById("log-copy");
    if (toggleBtn) {
      toggleBtn.addEventListener("click", function() {
        autoScroll = !autoScroll;
        toggleBtn.textContent = "Auto-scroll: " + (autoScroll ? "on" : "off");
      });
    }
    if (copyBtn) {
      copyBtn.addEventListener("click", function() {
        navigator.clipboard.writeText(logEl.textContent || "");
      });
    }

    if (status === "queued" || status === "running") {
      var source = new EventSource("/runs/" + logEl.dataset.runId + "/stream");
      source.onmessage = function(ev) {
        logEl.textContent += ev.data + "\n";
        if (autoScroll) {
          logEl.scrollTop = logEl.scrollHeight;
        }
      };
      source.onerror = function() {
        source.close();
      };
    }

    var searchInput = document.querySelector(".table-search");
    var chips = document.querySelectorAll(".chip");
    var rows = document.querySelectorAll("#exec-table tbody tr");
    var currentFilter = "all";

    chips.forEach(function(chip) {
      chip.addEventListener("click", function() {
        chips.forEach(function(c) { c.classList.remove("active"); });
        chip.classList.add("active");
        currentFilter = chip.dataset.filter;
        applyFilters();
      });
    });

    if (searchInput) {
      searchInput.addEventListener("input", applyFilters);
    }

    function applyFilters() {
      var query = searchInput ? searchInput.value.toLowerCase().trim() : "";
      rows.forEach(function(row) {
        var passesFilter = true;
        if (currentFilter !== "all") {
          if (currentFilter === "error") {
            passesFilter = row.dataset.failed === "true";
          } else {
            passesFilter = row.dataset.statusGroup === currentFilter;
          }
        }
        if (!passesFilter) {
          row.style.display = "none";
          return;
        }
        if (!query) {
          row.style.display = "";
          return;
        }
        var haystack = [
          row.dataset.method,
          row.dataset.name,
          row.dataset.url,
          row.dataset.status,
          row.dataset.time
        ].join(" ").toLowerCase();
        row.style.display = haystack.includes(query) ? "" : "none";
      });
    }

    document.querySelectorAll("#exec-table thead th[data-sort]").forEach(function(th) {
      th.addEventListener("click", function() {
        var key = th.dataset.sort;
        var dir = th.dataset.dir === "asc" ? "desc" : "asc";
        th.dataset.dir = dir;
        var sorted = Array.from(rows).sort(function(a, b) {
          var av = a.dataset[key] || "";
          var bv = b.dataset[key] || "";
          var num = key === "status" || key === "time";
          if (num) {
            av = Number(av);
            bv = Number(bv);
            return dir === "asc" ? av - bv : bv - av;
          }
          return dir === "asc" ? av.localeCompare(bv) : bv.localeCompare(av);
        });
        var tbody = document.querySelector("#exec-table tbody");
        sorted.forEach(function(row) { tbody.appendChild(row); });
      });
    });
  })();
</script>
